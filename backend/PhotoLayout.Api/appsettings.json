{
  "ConnectionStrings": {
    "Default": "Data Source=photolayout.db"
  },
  "Matting": {
    "Enabled": true,
    "OnnxModelPath": "onnx/u2net.onnx",
    "RemoveBlueBackdrop": false,
    "BlueBackdropAlphaCap": 0.08,
    "RefineBlueFringe": false,
    "ForegroundThreshold": 0.58,
    "EdgeSoftness": 0.12,
    "MaskPreBlurSigma": 1.35,
    "EdgeColorPullStrength": 0.42,
    "BlueSpillSuppression": 0.72,
    "PostCompositeBlueDefringe": 0.88
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
